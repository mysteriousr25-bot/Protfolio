# Copy this file to .env and fill values. Restart Vite after updating environment variables.
# EmailJS (do NOT commit your real keys to git)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here

# EmailJS template variables expected:
# from_name, from_email, inquiry_type, message
# Optional: destination inbox (if your template supports a `to_email` variable)
VITE_EMAILJS_DESTINATION_EMAIL=supriyahalder81000@gmail.com

# Server SMTP settings (optional) — to use server-side sending instead of EmailJS
# If you prefer server-side sending, set `VITE_USE_SERVER_EMAIL=true` and provide these values.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=supriyahalder81000@gmail.com
SMTP_PASS=xtfiqfahqsrvyygg
DESTINATION_EMAIL=supriyahalder81000@gmail.com
VITE_USE_SERVER_EMAIL=true
VITE_SERVER_URL=http://localhost:4000
# Backend runtime
PORT=4000
# Frontend origin allowed for CORS (Vite dev default)
FRONTEND_ORIGIN=http://localhost:5173
